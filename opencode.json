{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "confluence": {
      "type": "local",
      "command": ["npx", "-y", "@aashari/mcp-server-atlassian-confluence"],
      "env": {
        "ATLASSIAN_SITE_NAME": "https://dobbe.atlassian.net/wiki/",
        "ATLASSIAN_USER_EMAIL": "yadavakshay36912@gmail.com",
        "ATLASSIAN_API_TOKEN": "REPLACE_WITH_YOUR_TOKEN"
      },
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "@bitbonsai/mcpvault@latest",
        "/home/br4vetrave1er/Documents/br4vetrave1er notes"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "REPLACE_WITH_YOUR_TOKEN"
      },
      "enabled": true
    }
